rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      
      match /guardCircleDetails/{memberId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      
      match /quickDials/{dialId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      

      match /sosRecordings/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /evidenceRecordings/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
    
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /notifications/{uid}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == uid;
    }
    
    match /emergencySessions/{docId} {
      allow read, create, update: if request.auth != null;
    }
  }
}
